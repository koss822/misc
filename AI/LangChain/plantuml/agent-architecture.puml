@startuml langchain-agent-architecture
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Arial

title LangChain Ops Agent — Architecture

actor "Operator" as op

package "LangChain ReAct Agent" #LightGreen {
  component "Agent Executor" as agent
  component "Memory\n(ConversationBuffer)" as mem
}

package "Tools" {
  component "kubectl" as t1 #LightBlue
  component "prometheus_query" as t2 #LightBlue
  component "read_runbook" as t3 #LightBlue
  component "create_ticket" as t4 #LightBlue
}

cloud "Claude API\n(claude-sonnet-4-6)" as llm #FFD580
database "Vector Store\n(runbooks / FAISS)" as vs #EEE
database "K8s Cluster" as k8s #EEE
database "Prometheus" as prom #EEE
component "Jira / PagerDuty" as jira #EEE

op --> agent : incident description
agent <--> mem : conversation history
agent <--> llm : thought → action → observation loop

agent --> t1 : kubectl get/describe/logs
agent --> t2 : PromQL query
agent --> t3 : semantic search over runbooks
agent --> t4 : open incident ticket

t1 --> k8s
t2 --> prom
t3 --> vs
t4 --> jira

agent --> op : remediation plan (Markdown)

@enduml
